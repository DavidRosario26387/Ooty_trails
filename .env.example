# ──────────────────────────────────────────────────────────────
# OotyGo — Environment Variables
# Copy this file to `.env.local` for local dev, and set the same
# keys in the Render dashboard for production.
# ──────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (free M0 cluster).
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/ootygo?retryWrites=true&w=majority
MONGODB_URI=

# Long random secret used to sign JWT session tokens.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=

# Public base URL of the deployed site (used for SEO metadata / sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Business contact details surfaced across the public site.
NEXT_PUBLIC_PHONE=9345653427
NEXT_PUBLIC_WHATSAPP_NUMBER=9345653427
NEXT_PUBLIC_INSTAGRAM=https://instagram.com/

# OPTIONAL — set this to enable accurate Google road distances.
# Leave blank to use the free fallback (curated routes + OpenStreetMap geocoding).
GOOGLE_MAPS_API_KEY=

# Used ONLY by `npm run seed` to create the first admin account.
ADMIN_SEED_EMAIL=admin@ootygo.in
ADMIN_SEED_PASSWORD=ChangeMe123!
